cat > .gitignore << 'EOF'
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Production builds
dist/
build/
.out/
*.min.js

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Temporary / Cache folders
tmp/
.tmp/
temp/
.cache/
coverage/

# Browser / Chrome profile data (very important!)
chrome-*
tmp/chrome-*
Default/Cache/
Default/Code\ Cache/
Default/GPUCache/
Default/Service\ Worker/
Default/Session\ Storage/
Default/Local\ Storage/
Default/Network/Cookies*

# Logs
*.log
logs/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo

# Vite
vite.config.*.local.*
dist-ssr/

# Testing
cypress/screenshots/
cypress/videos/

# Misc
*.env
*.env.*
EOF