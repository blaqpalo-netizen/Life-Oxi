cat > .gitignore << 'EOF'
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Production / Build
dist/
build/
.out/
dist-ssr/

# Temporary / Cache
tmp/
.tmp/
temp/
.cache/
coverage/

# Environment
.env
.env.local
.env.*.local

# Browser/Chrome junk
chrome-*
tmp/chrome-*
Default/Cache/
Default/Code Cache/
Default/GPUCache/
Default/Service Worker/
Default/Session Storage/
Default/Local Storage/

# Logs & IDE
*.log
logs/
.vscode/
.idea/
.DS_Store
*.tsbuildinfo

# Misc
Thumbs.db
*.env
EOF
